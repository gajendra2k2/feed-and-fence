# Copy to .env and edit for your setup.

# Online mode calls a real Claude model for the Beat-6 multi-model routing demo.
# Offline mode returns canned responses for Beat 6 — use if conference Wi-Fi is unreliable.
OFFLINE_MODE=false
ANTHROPIC_API_KEY=

# Kafka bootstrap. Default matches docker-compose.yml.
KAFKA_BOOTSTRAP=localhost:9092

# MCP server.
MCP_HOST=127.0.0.1
MCP_PORT=8000

# Where the SQLite state file lives (approvals + order ledger).
STATE_DIR=./state
